{
    "swagger": "2.0",
    "info": {
        "title": "Solver API",
        "contact": {},
        "version": "0.0.1"
    },
    "basePath": "/api",
    "paths": {
        "/solve": {
            "post": {
                "description": "Receive order and packs variants and responds with optimal packing.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "summary": "Receive config for packing and respond accordingly.",
                "parameters": [
                    {
                        "description": "Request for task solution",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/api.Request"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/api.Response"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/api.ResponseErr"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/api.ResponseErr"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "api.Request": {
            "type": "object",
            "required": [
                "order",
                "packages"
            ],
            "properties": {
                "order": {
                    "type": "integer",
                    "minimum": 1
                },
                "packages": {
                    "type": "array",
                    "items": {
                        "type": "integer"
                    }
                }
            }
        },
        "api.Response": {
            "type": "object",
            "properties": {
                "packs": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "integer"
                    }
                }
            }
        },
        "api.ResponseErr": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string"
                }
            }
        }
    }
}